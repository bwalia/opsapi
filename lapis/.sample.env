# ============================================
# OpsAPI Local Development Environment
# ============================================
# Copy this file to .env: cp .sample.env .env
# Most defaults work out of the box for local development.

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_HOST=172.71.0.10
POSTGRES_PORT=5432
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpassword
POSTGRES_DB=opsapi

# ============================================
# JWT Authentication
# ============================================
# Generate a new key for production: openssl rand -base64 32
JWT_SECRET_KEY=dev-jwt-secret-change-in-production

# ============================================
# AES Encryption (AES-128-CBC)
# ============================================
# Requires 16-byte key and IV (32 hex characters each)
# Generate new keys for production: openssl rand -hex 16
OPENSSL_SECRET_KEY=8151d12b939a4670a9c3e5f7b2d4c6e8
OPENSSL_SECRET_IV=9abd41f7eec7635e1a2b3c4d5e6f7081

# ============================================
# SSL Verification
# ============================================
# Set to "true" in production with proper CA certificates
OPSAPI_SSL_VERIFY=false

# ============================================
# MinIO (S3-compatible Object Storage)
# ============================================
MINIO_ENDPOINT=http://172.71.0.17:9000
MINIO_ENDPOINT_WEB_EXTERNAL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=opsapi
MINIO_REGION=us-east-1

# ============================================
# Dashboard & API URLs
# ============================================
# Automatically updated by start.sh based on environment
NEXT_PUBLIC_API_URL=http://127.0.0.1:4010

# ============================================
# Node API (Optional)
# ============================================
NODE_API_URL=http://172.71.0.14/api

# ============================================
# CORS Configuration (Optional)
# ============================================
# Comma-separated domain names (allows domain + all subdomains + any port)
# CORS_ALLOWED_DOMAINS=example.com,myapp.com
# Comma-separated explicit origin URLs
# CORS_ALLOWED_ORIGINS=http://myserver:8039

# ============================================
# Kafka (Optional - Event Streaming)
# ============================================
# Kafka broker addresses (comma-separated host:port pairs)
# KAFKA_BROKERS=kafka:29092

# ============================================
# Google OAuth (Optional)
# ============================================
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:4010/auth/google/callback

# ============================================
# Keycloak SSO (Optional)
# ============================================
# KEYCLOAK_AUTH_URL=https://your-keycloak/realms/opsapi/protocol/openid-connect/auth
# KEYCLOAK_TOKEN_URL=https://your-keycloak/realms/opsapi/protocol/openid-connect/token
# KEYCLOAK_USERINFO_URL=https://your-keycloak/realms/opsapi/protocol/openid-connect/userinfo
# KEYCLOAK_CLIENT_ID=opsapi
# KEYCLOAK_CLIENT_SECRET=your-client-secret
KEYCLOAK_REDIRECT_URI=http://127.0.0.1:4010/auth/callback

# ============================================
# Stripe (Optional)
# ============================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
