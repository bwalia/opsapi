{
  "id": "minio-prod-default",
  "name": "minio-prod-default",
  "profile_id": "prod",
  "priority": 1,
  "rules_tags": ["minio", "s3", "workstation", "prod"],
  "match": {
    "rules": {
      "path": "/",
      "path_key": "starts_with",
      "jwt_token_validation": "equals"
    },
    "response": {
      "code": 305,
      "redirect_uri": "13.42.188.136:80",
      "strip_path": false,
      "backends": [
        {
          "address": "13.42.188.136:80",
          "weight": 100,
          "label": "k3s1 traefik ingress (wslproxy class); routes by Host to diytaxreturn-minio:9000 (S3 API)"
        }
      ],
      "routing": {
        "mode": "least_conn"
      }
    }
  },
  "servers": [
    "host:int-minio.workstation.co.uk",
    "host:test-minio.workstation.co.uk",
    "host:acc-minio.workstation.co.uk"
  ]
}
